{
  "name": "hermetia-marketing",
  "version": "0.1.0",
  "private": true,
  "description": "Hermetia — Marketing-Basisseite (Next.js SSG, i18n DE/EN)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:i18n": "next build && node scripts/apply-i18n-html-translations.mjs --generate-missing",
    "i18n:extract": "node scripts/extract-i18n-source-catalog.mjs",
    "i18n:apply": "node scripts/apply-i18n-html-translations.mjs",
    "i18n:parity": "node scripts/check-i18n-content-parity.mjs",
    "i18n:live-parity": "node scripts/check-i18n-live-parity.mjs",
    "check:assets": "node scripts/check-assets.mjs",
    "check:content": "node scripts/check-content.mjs",
    "check:compliance": "node scripts/check-compliance.mjs",
    "check:i18n:export": "node scripts/check-i18n-export.mjs --changed",
    "check:i18n:live": "node scripts/check-i18n-live.mjs",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3"
  }
}
