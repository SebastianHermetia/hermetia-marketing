# Basis-URL der Marketing-Seite (canonical, hreflang, sitemap).
# Vorerst hermetiastart.digital-expert.de; vor Launch auf eigene Domain ändern.
NEXT_PUBLIC_SITE_URL=https://hermetiastart.digital-expert.de

# URL der App (Onboarding + Login leben in der bestehenden Hermetia-App).
NEXT_PUBLIC_APP_URL=https://hermetia.digital-expert.de

# PostHog (Analytics). GLEICHES Projekt wie die App verwenden, damit Marketing-
# und App-Events in einem Funnel landen: denselben Project-API-Key (App-ENV
# NEXT_PUBLIC_POSTHOG_KEY / POSTHOG_PROJECT_API_KEY) + EU-Host eintragen.
# Ist der Key leer, ist die gesamte Analytics-Schicht ein No-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
